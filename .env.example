# AutoClick Configuration
# Copy this file to .env and fill in your values
#
# macOS Guest Account: скопируйте проект в /Users/Shared/auto-click/
# Файлы сохраняются между сессиями. См. GUEST_MODE.md

# Email for dashboard login
EMAIL=your@email.com

# Password for dashboard login
PASSWORD=your_password

# Telegram bot token (from @BotFather)
TELEGRAM_TOKEN=your_bot_token

# Optional settings (defaults shown):
# TARGET_URL=https://dashboard.tomorrow-school.ai
# MAX_HOURS=10
# MIN_INTERVAL_MIN=5
# MAX_INTERVAL_MIN=12
# HEADLESS=true
# SLOW_MO=0
# AUTO_START=false
