# AutoClick Configuration
# Copy this file to .env and fill in your values

# Email for dashboard login
EMAIL=your@email.com

# Password for dashboard login
PASSWORD=your_password

# Telegram bot token (from @BotFather)
TELEGRAM_TOKEN=your_bot_token

# Optional settings (defaults shown):
# TARGET_URL=https://dashboard.tomorrow-school.ai
# MAX_HOURS=10
# MIN_INTERVAL_MIN=5
# MAX_INTERVAL_MIN=12
# HEADLESS=true
# SLOW_MO=0
# AUTO_START=false

# ─── Multi-Machine Coordination (optional) ───
# If not set, machine name is auto-detected from OS hostname
# MACHINE_NAME=My-Computer

# GitHub Gist for coordination between machines
# 1. Create a gist at https://gist.github.com with an empty file "machine-lock.json" containing {}
# 2. Get the Gist ID from the URL (https://gist.github.com/user/GIST_ID)
# 3. Create a GitHub Personal Access Token with 'gist' scope at https://github.com/settings/tokens
# GIST_ID=your_gist_id_here
# GITHUB_TOKEN=ghp_your_token_here
