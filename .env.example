# AutoClick Configuration
# Copy this file to .env and fill in your values

# ─── Remote Config from Gist ───
# Bot loads EMAIL/PASSWORD/TELEGRAM_TOKEN/GIST_ID from this Gist's config.json.
# Create a gist with a "config.json" file, e.g.:
# {
#   "EMAIL": "your@email.com",
#   "PASSWORD": "your_password",
#   "TELEGRAM_TOKEN": "your_bot_token",
#   "GIST_ID": "coordination_gist_id"
# }
# WARNING: Do NOT put GITHUB_TOKEN in the gist - GitHub auto-revokes exposed tokens!
CONFIG_GIST_ID=your_config_gist_id

# GitHub Personal Access Token with 'gist' scope, for multi-machine coordination
# (create at https://github.com/settings/tokens). Must be set locally on each machine.
GITHUB_TOKEN=ghp_your_token_here
